      "opacity": 1,
      "y_px": 0,
      "blur_px": 0,
      "scale": 1
    },
    "to": {
      "opacity": 0,
      "y_px": -10,
      "blur_px": 10,
      "scale": 1
    }
  },
  "swap": {
    "mode": "crossfade",
    "overlap_ms": 160,
    "micro_delay_ms": 35
